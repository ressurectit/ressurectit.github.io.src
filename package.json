        "@anglr/grid": "11.0.0",
        "@anglr/md-help": "11.0.0",
        "@anglr/notifications": "12.0.1",
        "@anglr/rest": "14.0.0",
        "@anglr/select": "16.0.0",
        "@anglr/server-stuff": "9.0.0",
        "@anglr/translate-extensions": "12.0.0",
        "@angular/cdk": "21.2.5",
        "@angular/common": "21.2.7",
        "@angular/compiler": "21.2.7",
        "@angular/core": "21.2.7",
        "@angular/forms": "21.2.7",
        "@angular/material": "21.2.5",
        "@angular/platform-browser": "21.2.7",
        "@angular/platform-browser-dynamic": "21.2.7",
        "@angular/platform-server": "21.2.7",
        "@angular/router": "21.2.7",
        "@angular/service-worker": "21.2.7",
        "@angular/ssr": "21.2.6",
        "@css-styles/common": "2.0.1",
        "@css-styles/themes": "2.4.0",
        "@floating-ui/dom": "1.7.6",
